{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics 워크스페이스 이름(dah-data-law)"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces/tables",
      "apiVersion": "2022-10-01",
      "name": "[concat(parameters('workspaceName'), '/UAVFileAudit_CL')]",
      "properties": {
        "schema": {
          "name": "UAVFileAudit_CL",
          "columns": [
            {
              "name": "TimeGenerated",
              "type": "datetime"
            },
            {
              "name": "ContainerName",
              "type": "string"
            },
            {
              "name": "Pid",
              "type": "int"
            },
            {
              "name": "ProcessName",
              "type": "string"
            },
            {
              "name": "Operation",
              "type": "string"
            },
            {
              "name": "FilePath",
              "type": "string"
            },
            {
              "name": "BytesAccessed",
              "type": "long"
            },
            {
              "name": "User",
              "type": "string"
            },
            {
              "name": "Syscall",
              "type": "string"
            }
          ]
        },
        "retentionInDays": 30,
        "totalRetentionInDays": 90
      }
    }
  ]
}

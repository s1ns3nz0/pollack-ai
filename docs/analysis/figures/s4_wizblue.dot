   M[label="병합 + LLM 종합\n(verdict·근거·권고)" fillcolor="#a5d8ff" color="#1864ab"]; }
 V[label="Validation"]; R[label="Response"]; U[label="RuleUpdate"]; P[label="Report"];
 T->F; T->Ti; T->C; F->M; Ti->M; C->M; M->V; V->R[label="정탐"]; V->U[label="오탐"]; R->P; U->P;

# ─────────────────────────────────────────
# UAV AI SOC Platform — 환경변수 템플릿
# ─────────────────────────────────────────
# 이 파일을 복사해서 .env로 만들고 실제 값을 채워넣을 것
# cp .env.example .env
#
# ❌ .env는 절대 git에 커밋하지 말 것 (.gitignore에 포함됨)
# ✅ 이 파일(.env.example)은 git에 커밋해도 됨 (실제 값 없음)
# ─────────────────────────────────────────

# ── Azure OpenAI ──────────────────────────
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Azure Sentinel ────────────────────────
SENTINEL_WORKSPACE_ID=
SENTINEL_RESOURCE_GROUP=
SENTINEL_SUBSCRIPTION_ID=
SENTINEL_TENANT_ID=

# ── Azure 인증 (Service Principal) ────────
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ── GraphRAG ──────────────────────────────
GRAPHRAG_STORAGE_ACCOUNT=
GRAPHRAG_CONTAINER_NAME=uav-knowledge-base

# ── RAGFlow (로컬 RAG — tools/ragflow_tool.py) ─
RAGFLOW_BASE_URL=http://127.0.0.1:9380
RAGFLOW_API_TOKEN=
RAGFLOW_DATASET_ID=
RAGFLOW_SIMILARITY_THRESHOLD=0.2
RAGFLOW_VECTOR_WEIGHT=0.4
RAGFLOW_TOP_K=1024
RAGFLOW_TIMEOUT_SECONDS=60

# ── LLM (구현단계=Ollama, 추후 Azure 로 교체) ─
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://192.168.64.1:11443
OLLAMA_CHAT_MODEL=qwen2.5:14b
LLM_TIMEOUT_SECONDS=120

# ── PyRIT (Red Teaming) ───────────────────
MAX_PYRIT_ITERATIONS=50

# ── RAGAS (평가) ──────────────────────────
RAGAS_FAITHFULNESS_THRESHOLD=0.8
RAGAS_ANSWER_RELEVANCY_THRESHOLD=0.8
RAGAS_CONTEXT_RELEVANCY_THRESHOLD=0.8

# ── 분석/증거 고도화 opt-in ───────────────
LINEAGE_ENABLED=false
CYBER_POSTURE_LEVEL=5
PREDICT_MIN_SUPPORT=3
PREDICT_MIN_PROBABILITY=0.5
PREDICT_TOP_K=3
CAUSAL_RULES_PATH=core/policy/causal-rules.yaml
CAUSAL_LLM_EXPLAIN=false

# ── 위협 피드 / 자동 룰 제안 ───────────────
FEED_REFRESH_HOURS=24
FEED_USER_AGENT=pollack-ai-threat-landscape/1.0
FEED_ADDED_CAP=100
ATTACK_FEED_URL=https://raw.githubusercontent.com/mitre/cti/master/enterprise-attack/enterprise-attack.json
ATLAS_FEED_URL=https://raw.githubusercontent.com/mitre-atlas/atlas-data/main/dist/ATLAS.yaml
EMBED3D_FEED_URL=
KEV_FEED_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
AUTO_KQL_ENABLED=false
AUTO_KQL_MAX_TECHNIQUES=5

# ── Active Hunt (Sentinel KQL 능동 헌팅) ───
ACTIVE_HUNT_ENABLED=false
ACTIVE_HUNT_POLICY_PATH=core/policy/active-hunt.yaml

# ── 탐지룰 저장소 (Watch List 자동 갱신) ───
# RuleUpdateAgent 가 오탐 개선을 Watch List 변경 PR 로 올린다(KQL 불변).
SENTINEL_CONTENT_REPO=s1ns3nz0/dah-sentinel-content
GITHUB_TOKEN=
GITHUB_BASE_URL=https://api.github.com
RULE_BRANCH_PREFIX=feat/watchlist
GITHUB_TIMEOUT_SECONDS=20

# ── 외부 enrich (TI/샌드박스/취약점) — 방산 OPSEC default-deny ───
# 마스터 스위치. 외부 조회는 수사의도를 외부(+관전 적)에 누설하므로 기본 OFF.
# TI/샌드박스/vuln 을 hotpath 에서 켜려면 true + 아래 per-source API 키 설정.
# (GNSS/Airspace 는 이 플래그와 무관 — 각자 URL 게이트로 별도 배선.)
EXTERNAL_ENRICHMENT_ENABLED=false
# untrusted wire IOC egress 상한(alert당 단일 outbound 예산 — 쿼터번 방지).
IOC_EGRESS_MAX_PER_ALERT=32
# enrich 호출당 벽시계 데드라인(초) — 직렬 다중 IOC 조회 hotpath 정체 방지(fail-open).
ENRICHMENT_DEADLINE_SECONDS=20
# per-source API 키(비면 해당 소스 비활성). CISA KEV 는 키 불요(공개).
VIRUSTOTAL_API_KEY=
GREYNOISE_API_KEY=
ABUSEIPDB_API_KEY=
THREATFOX_API_KEY=
HYBRIDANALYSIS_API_KEY=
NVD_API_KEY=

# ── Malware analysis MCP (UAV firmware / Linux GCS) — default-deny ───
# Static-only 자동 분석도 기본 OFF. Firmware/Ghidra/dynamic execution 은 수동 승인 필요.
MALWARE_ANALYSIS_ENABLED=false
MALWARE_ANALYSIS_AUTO_STATIC_ENABLED=false
MALWARE_ANALYSIS_MANUAL_EXECUTION_ENABLED=false
EXTERNAL_SAMPLE_UPLOAD_ENABLED=false
MALWARE_ANALYSIS_AUTO_MAX_BYTES=10485760
MALWARE_ANALYSIS_DEADLINE_SECONDS=30
MALWARE_MCP_FIRMWARE_SERVER=
MALWARE_MCP_LINUX_SERVER=
MALWARE_MCP_GHIDRA_SERVER=
MALWARE_MCP_SANDBOX_SERVER=

# ── 대시보드 서버 ──────────────────────────────
# DASHBOARD_PUBLIC_URL 에 Azure 공개 도메인을 넣으면 외부 접속용으로 0.0.0.0 에
# 바인드된다(예: https://uav-soc.koreacentral.cloudapp.azure.com).
# 비워 두면 기본값 — 로컬(127.0.0.1)에서만 접속 가능.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8791
DASHBOARD_PUBLIC_URL=

# ── 로깅 ──────────────────────────────────
LOG_LEVEL=INFO

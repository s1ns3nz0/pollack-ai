# ─────────────────────────────────────────
# UAV AI SOC Platform — 환경변수 템플릿
# ─────────────────────────────────────────
# 이 파일을 복사해서 .env로 만들고 실제 값을 채워넣을 것
# cp .env.example .env
#
# ❌ .env는 절대 git에 커밋하지 말 것 (.gitignore에 포함됨)
# ✅ 이 파일(.env.example)은 git에 커밋해도 됨 (실제 값 없음)
# ─────────────────────────────────────────

# ── Azure OpenAI ──────────────────────────
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Azure Sentinel ────────────────────────
SENTINEL_WORKSPACE_ID=
SENTINEL_RESOURCE_GROUP=
SENTINEL_SUBSCRIPTION_ID=
SENTINEL_TENANT_ID=

# ── Azure 인증 (Service Principal) ────────
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ── GraphRAG ──────────────────────────────
GRAPHRAG_STORAGE_ACCOUNT=
GRAPHRAG_CONTAINER_NAME=uav-knowledge-base

# ── RAGFlow (로컬 RAG — tools/ragflow_tool.py) ─
RAGFLOW_BASE_URL=http://127.0.0.1:9380
RAGFLOW_API_TOKEN=
RAGFLOW_DATASET_ID=
RAGFLOW_SIMILARITY_THRESHOLD=0.2
RAGFLOW_VECTOR_WEIGHT=0.4
RAGFLOW_TOP_K=1024
RAGFLOW_TIMEOUT_SECONDS=60

# ── LLM (구현단계=Ollama, 추후 Azure 로 교체) ─
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://192.168.64.1:11443
OLLAMA_CHAT_MODEL=qwen2.5:14b
LLM_TIMEOUT_SECONDS=120

# ── PyRIT (Red Teaming) ───────────────────
MAX_PYRIT_ITERATIONS=50

# ── RAGAS (평가) ──────────────────────────
RAGAS_FAITHFULNESS_THRESHOLD=0.8
RAGAS_RELEVANCY_THRESHOLD=0.8
RAGAS_CONTEXT_PRECISION_THRESHOLD=0.8

# ── 탐지룰 저장소 (Watch List 자동 갱신) ───
# RuleUpdateAgent 가 오탐 개선을 Watch List 변경 PR 로 올린다(KQL 불변).
SENTINEL_CONTENT_REPO=s1ns3nz0/dah-sentinel-content
GITHUB_TOKEN=
GITHUB_BASE_URL=https://api.github.com
RULE_BRANCH_PREFIX=feat/watchlist
GITHUB_TIMEOUT_SECONDS=20

# ── 외부 enrich (TI/샌드박스/취약점) — 방산 OPSEC default-deny ───
# 마스터 스위치. 외부 조회는 수사의도를 외부(+관전 적)에 누설하므로 기본 OFF.
# TI/샌드박스/vuln 을 hotpath 에서 켜려면 true + 아래 per-source API 키 설정.
# (GNSS/Airspace 는 이 플래그와 무관 — 각자 URL 게이트로 별도 배선.)
EXTERNAL_ENRICHMENT_ENABLED=false
# untrusted wire IOC egress 상한(alert당 단일 outbound 예산 — 쿼터번 방지).
IOC_EGRESS_MAX_PER_ALERT=32
# enrich 호출당 벽시계 데드라인(초) — 직렬 다중 IOC 조회 hotpath 정체 방지(fail-open).
ENRICHMENT_DEADLINE_SECONDS=20
# per-source API 키(비면 해당 소스 비활성). CISA KEV 는 키 불요(공개).
VIRUSTOTAL_API_KEY=
GREYNOISE_API_KEY=
ABUSEIPDB_API_KEY=
THREATFOX_API_KEY=
HYBRIDANALYSIS_API_KEY=
NVD_API_KEY=

# ── 로깅 ──────────────────────────────────
LOG_LEVEL=INFO
